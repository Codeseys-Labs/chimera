{
  "name": "@chimera/tests",
  "version": "0.1.0",
  "description": "Integration, E2E, and load tests for AWS Chimera platform",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:load": "jest tests/load --runInBand --maxWorkers=1",
    "test:helpers": "jest tests/helpers",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@chimera/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@chimera/(.*)$": "<rootDir>/../packages/$1/src"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!**/*.test.ts",
      "!**/*.spec.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testTimeout": 60000,
    "verbose": true
  },
  "keywords": [
    "chimera",
    "testing",
    "integration",
    "e2e",
    "load-testing",
    "aws",
    "bedrock"
  ],
  "author": "AWS Chimera Team",
  "license": "Apache-2.0"
}
