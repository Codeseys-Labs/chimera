{
  "name": "@chimera/chat-gateway",
  "version": "0.1.0",
  "description": "Express HTTP gateway for AWS Chimera multi-tenant agent platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "bun run --watch src/server.ts",
    "test": "jest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chimera/shared": "workspace:*",
    "@chimera/core": "workspace:*",
    "@chimera/sse-bridge": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "chimera",
    "agent",
    "gateway",
    "express",
    "sse",
    "multi-tenant"
  ],
  "author": "AWS Chimera Team",
  "license": "Apache-2.0"
