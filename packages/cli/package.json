{
  "name": "@chimera/cli",
  "version": "0.1.0",
  "description": "CLI for the AWS Chimera multi-tenant agent platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chimera": "./bin/chimera"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "compile": "bun build src/cli.ts --compile --outfile chimera",
    "compile:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile chimera-linux-x64",
    "compile:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile chimera-linux-arm64",
    "compile:darwin-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile chimera-darwin-x64",
    "compile:darwin-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile chimera-darwin-arm64",
    "compile:windows-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile chimera-windows-x64.exe",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64 && bun run compile:windows-x64",
    "test": "bun test",
    "lint": "eslint src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chimera",
    "cli",
    "aws",
    "multi-tenant",
    "agent",
    "platform"
  ],
  "author": "Chimera Platform",
  "license": "Apache-2.0",
  "dependencies": {
    "@chimera/shared": "workspace:*",
    "@chimera/core": "workspace:*",
    "commander": "^11.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.1",
    "react": "^18.3.0",
    "smol-toml": "^1.3.1",
    "react-devtools-core": "^5.0.0",
    "table": "^6.8.1"
  },
  "peerDependencies": {
    "@aws-sdk/client-codecommit": "^3.0.0",
    "@aws-sdk/client-codepipeline": "^3.0.0",
    "@aws-sdk/client-cloudformation": "^3.0.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "aws-cdk": "^2.1112.0",
    "eslint": "8.57.1",
    "ink-testing-library": "^4.0.0",
    "typescript": "~5.7.0"
  }
}
