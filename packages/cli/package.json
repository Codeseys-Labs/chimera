{
  "name": "@chimera/cli",
  "version": "0.1.0",
  "description": "CLI for the AWS Chimera multi-tenant agent platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chimera": "./bin/chimera"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chimera",
    "cli",
    "aws",
    "multi-tenant",
    "agent",
    "platform"
  ],
  "author": "Chimera Platform",
  "license": "Apache-2.0",
  "dependencies": {
    "@chimera/shared": "workspace:*",
    "@chimera/core": "workspace:*",
    "commander": "^11.1.0",
    "chalk": "^5.6.2",
    "inquirer": "^9.2.0",
    "ora": "^8.0.1",
    "table": "^6.8.1"
  },
  "peerDependencies": {
    "@aws-sdk/client-codecommit": "^3.0.0",
    "@aws-sdk/client-codepipeline": "^3.0.0",
    "@aws-sdk/client-cloudformation": "^3.0.0"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.4",
    "@types/inquirer": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "~5.7.0"
  }
}
