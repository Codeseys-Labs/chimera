{
  "name": "chimera-monorepo",
  "version": "0.1.0",
  "description": "AWS Chimera - Multi-tenant agent platform monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "infra",
    "tests"
  ],
  "scripts": {
    "build": "bun run build:shared && bun run build:packages && bun run build:infra",
    "build:shared": "cd packages/shared && bun run build",
    "build:packages": "bun run build:core && bun run build:sse-bridge && bun run build:chat-gateway && bun run build:cli",
    "build:core": "cd packages/core && bun run build",
    "build:sse-bridge": "cd packages/sse-bridge && bun run build",
    "build:chat-gateway": "cd packages/chat-gateway && bun run build",
    "build:cli": "cd packages/cli && bun run build",
    "build:infra": "cd infra && bun run build",
    "compile:dev": "cd packages/cli && bun build src/cli.ts --compile --outfile ../../chimera",
    "compile:cli": "cd packages/cli && bun run compile",
    "compile:cli:all": "cd packages/cli && bun run compile:all",
    "test": "bun test ./packages/shared/ ./packages/core/ ./packages/sse-bridge/ ./packages/chat-gateway/ ./packages/cli/ ./infra/",
    "test:all": "bun run test:shared && bun run test:core && bun run test:sse-bridge && bun run test:chat-gateway && bun run test:cli && bun run test:infra && bun run test:integration",
    "test:integration": "cd tests && bun run test:integration",
    "test:e2e": "cd tests && bun run test:e2e",
    "test:playwright": "npx playwright test",
    "test:load": "cd tests && bun run test:load",
    "test:shared": "cd packages/shared && bun test",
    "test:core": "cd packages/core && bun test",
    "test:sse-bridge": "cd packages/sse-bridge && bun test",
    "test:chat-gateway": "cd packages/chat-gateway && bun test",
    "test:cli": "cd packages/cli && bun test",
    "test:infra": "cd infra && bun test",
    "lint": "bun run lint:packages && bun run lint:infra",
    "lint:packages": "cd packages/shared && bun run lint && cd ../core && bun run lint && cd ../sse-bridge && bun run lint && cd ../chat-gateway && bun run lint && cd ../cli && bun run lint",
    "lint:infra": "cd infra && bun run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretypecheck": "cd packages/shared && bunx tsc --build --force",
    "typecheck": "tsc --build",
    "clean": "bun run clean:packages && bun run clean:infra",
    "clean:packages": "rm -rf packages/*/dist packages/*/node_modules",
    "clean:infra": "rm -rf infra/dist infra/cdk.out",
    "dev": "cd packages/chat-gateway && bun run dev",
    "dev:gateway": "cd packages/chat-gateway && bun run dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "seed": "cd seed-data && bun run seed.ts",
    "seed:tables": "cd seed-data && bun run seed.ts --create-tables",
    "seed:data": "cd seed-data && bun run seed.ts --seed-data",
    "seed:reset": "cd seed-data && bun run seed.ts --delete-tables && bun run seed.ts",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-athena": "^3.1016.0",
    "@aws-sdk/client-bedrock": "^3.1016.0",
    "@aws-sdk/client-bedrock-agent": "^3.1016.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1016.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1016.0",
    "@aws-sdk/client-cloudformation": "^3.1016.0",
    "@aws-sdk/client-cloudfront": "^3.1016.0",
    "@aws-sdk/client-cloudwatch": "^3.1016.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1016.0",
    "@aws-sdk/client-codebuild": "^3.1016.0",
    "@aws-sdk/client-codecommit": "^3.1016.0",
    "@aws-sdk/client-codepipeline": "^3.1016.0",
    "@aws-sdk/client-config-service": "^3.1016.0",
    "@aws-sdk/client-cost-explorer": "^3.1016.0",
    "@aws-sdk/client-dynamodb": "^3.1016.0",
    "@aws-sdk/client-ec2": "^3.1016.0",
    "@aws-sdk/client-ecs": "^3.1016.0",
    "@aws-sdk/client-efs": "^3.1016.0",
    "@aws-sdk/client-eventbridge": "^3.1016.0",
    "@aws-sdk/client-glue": "^3.1016.0",
    "@aws-sdk/client-iam": "^3.1016.0",
    "@aws-sdk/client-lambda": "^3.1016.0",
    "@aws-sdk/client-opensearch": "^3.1016.0",
    "@aws-sdk/client-organizations": "^3.1016.0",
    "@aws-sdk/client-rds": "^3.1016.0",
    "@aws-sdk/client-redshift": "^3.1016.0",
    "@aws-sdk/client-rekognition": "^3.1016.0",
    "@aws-sdk/client-resource-explorer-2": "^3.1016.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.1016.0",
    "@aws-sdk/client-route-53": "^3.1016.0",
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/client-sagemaker": "^3.1016.0",
    "@aws-sdk/client-sfn": "^3.1016.0",
    "@aws-sdk/client-sqs": "^3.1016.0",
    "@aws-sdk/client-sts": "^3.1016.0",
    "@aws-sdk/client-textract": "^3.1016.0",
    "@aws-sdk/client-transcribe": "^3.1016.0",
    "@aws-sdk/client-verifiedpermissions": "^3.1016.0",
    "@aws-sdk/client-wafv2": "^3.1016.0",
    "@aws-sdk/client-wellarchitected": "^3.1016.0",
    "@aws-sdk/lib-dynamodb": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "8.57.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1019.0",
    "@types/bun": "^1.3.11",
    "js-yaml": "^4.1.1"
  }
}
