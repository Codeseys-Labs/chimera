# AWS Chimera - Local Development Environment Variables
# Copy this file to .env and customize for your environment

# ============================================================================
# AWS Configuration (Local Development)
# ============================================================================

# AWS Region
AWS_REGION=us-east-1

# AWS Credentials (for LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# LocalStack endpoint
AWS_ENDPOINT=http://localhost:4566

# DynamoDB Local endpoint
DYNAMODB_ENDPOINT=http://localhost:8000

# ============================================================================
# Service Configuration
# ============================================================================

# Node environment
NODE_ENV=development

# Chat Gateway port
PORT=8080

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# ============================================================================
# AgentCore Runtime Configuration
# ============================================================================

# AgentCore Runtime endpoint ARN (mock for local dev)
AGENTCORE_RUNTIME_ENDPOINT_ARN=arn:aws:bedrock:us-east-1:123456789012:agent-runtime/mock-runtime

# Memory strategy tier (SUMMARY, USER_PREFERENCE, LONG_TERM)
AGENTCORE_MEMORY_STRATEGY=SUMMARY

# Session timeout in seconds
AGENTCORE_SESSION_TIMEOUT=3600

# ============================================================================
# Bedrock Model Configuration
# ============================================================================

# Default model ID for agents
DEFAULT_MODEL_ID=us.anthropic.claude-sonnet-4-6-v1:0

# Bedrock region (for actual API calls - not mocked)
BEDROCK_REGION=us-east-1

# Bedrock endpoint (leave empty for production, set for testing)
# BEDROCK_ENDPOINT=

# ============================================================================
# DynamoDB Table Names
# ============================================================================

# Tenant table
DYNAMODB_TABLE_TENANTS=chimera-tenants-local

# Session table
DYNAMODB_TABLE_SESSIONS=chimera-sessions-local

# Skill table
DYNAMODB_TABLE_SKILLS=chimera-skills-local

# Rate limit table
DYNAMODB_TABLE_RATE_LIMITS=chimera-rate-limits-local

# Cost tracking table
DYNAMODB_TABLE_COST_TRACKING=chimera-cost-tracking-local

# Audit table
DYNAMODB_TABLE_AUDIT=chimera-audit-local

# ============================================================================
# S3 Configuration
# ============================================================================

# S3 bucket for tenant data
S3_BUCKET_TENANT_DATA=chimera-tenant-data-local

# S3 bucket for skill packages
S3_BUCKET_SKILL_PACKAGES=chimera-skill-packages-local

# S3 bucket for agent outputs
S3_BUCKET_AGENT_OUTPUTS=chimera-agent-outputs-local

# ============================================================================
# SQS Configuration
# ============================================================================

# SQS queue for async agent tasks
SQS_QUEUE_URL_AGENT_TASKS=http://localhost:4566/000000000000/chimera-agent-tasks-local

# SQS queue for DLQ
SQS_QUEUE_URL_DLQ=http://localhost:4566/000000000000/chimera-dlq-local

# ============================================================================
# EventBridge Configuration
# ============================================================================

# EventBridge event bus name
EVENTBRIDGE_BUS_NAME=chimera-events-local

# ============================================================================
# Rate Limiting & Quotas
# ============================================================================

# Default rate limit (requests per minute)
DEFAULT_RATE_LIMIT_RPM=100

# Default monthly quota (USD)
DEFAULT_MONTHLY_QUOTA_USD=1000

# ============================================================================
# Security & Authentication
# ============================================================================

# Cognito User Pool ID (for production auth, not used in local dev)
# COGNITO_USER_POOL_ID=

# Cognito App Client ID
# COGNITO_APP_CLIENT_ID=

# JWT secret for local development (DO NOT USE IN PRODUCTION)
JWT_SECRET=local-dev-secret-change-me-in-production

# Cedar policy store ID (for production, not used in local dev)
# CEDAR_POLICY_STORE_ID=

# ============================================================================
# Skill Marketplace Configuration
# ============================================================================

# Skill registry DynamoDB table
SKILL_REGISTRY_TABLE=chimera-skill-registry-local

# Skill packages S3 bucket
SKILL_PACKAGES_BUCKET=chimera-skill-packages-local

# MCP Gateway URL (for MCP skill discovery)
MCP_GATEWAY_URL=http://localhost:9000

# ============================================================================
# Observability
# ============================================================================

# CloudWatch log group (not used in local dev)
# CLOUDWATCH_LOG_GROUP=/aws/chimera/local

# X-Ray daemon endpoint (not used in local dev)
# XRAY_DAEMON_ADDRESS=

# Enable debug logging
DEBUG=chimera:*

# ============================================================================
# Hot Reload Configuration
# ============================================================================

# Enable hot reload for chat-gateway (Bun watch mode)
HOT_RELOAD_ENABLED=true

# Watch directories (comma-separated)
HOT_RELOAD_WATCH_DIRS=packages/chat-gateway/src,packages/core/src,packages/shared/src,packages/sse-bridge/src

# ============================================================================
# Testing Configuration
# ============================================================================

# Test tenant ID
TEST_TENANT_ID=tenant-test-001

# Test user ID
TEST_USER_ID=user-test-001

# Test mode (skips external API calls)
TEST_MODE=false

# ============================================================================
# Feature Flags
# ============================================================================

# Enable experimental features
EXPERIMENTAL_FEATURES_ENABLED=true

# Enable self-evolution module
EVOLUTION_MODULE_ENABLED=false

# Enable multi-agent orchestration
MULTI_AGENT_ORCHESTRATION_ENABLED=true

# Enable skill marketplace
SKILL_MARKETPLACE_ENABLED=true
