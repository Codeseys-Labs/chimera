# Chimera deployment configuration
# Generated by: chimera init
# Copy to chimera.toml and fill in your values.

[aws]
profile = "your-aws-profile"
region = "us-west-2"

[workspace]
environment = "dev"
repository = "chimera"

[auth]
admin_email = "admin@example.com"

# The following sections are populated by `chimera deploy` and `chimera endpoints`.
# Do NOT commit chimera.toml to version control — it contains deployment-specific values.

# [deployment]
# status = "deployed"
# account_id = "123456789012"
# last_deployed = "2026-01-01T00:00:00.000Z"

# [endpoints]
# api_url = "https://xxx.execute-api.us-west-2.amazonaws.com/dev/"
# chat_url = "http://chimera-chat-dev-xxx.us-west-2.elb.amazonaws.com"
# frontend_url = "https://dxxxxxxxxxx.cloudfront.net"
# websocket_url = "wss://xxx.execute-api.us-west-2.amazonaws.com/dev"
# cognito_user_pool_id = "us-west-2_XXXXXXXXX"
# cognito_client_id = "xxxxxxxxxxxxxxxxxxxxxxxxxx"
# cognito_domain = "chimera-dev-123456789012"
