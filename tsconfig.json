{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@chimera/shared": ["./packages/shared/src"],
      "@chimera/core": ["./packages/core/src"],
      "@chimera/sse-bridge": ["./packages/sse-bridge/src"],
      "@chimera/chat-gateway": ["./packages/chat-gateway/src"]
    }
  },
  "files": [],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/core" },
    { "path": "./packages/sse-bridge" },
    { "path": "./packages/chat-gateway" },
    { "path": "./infra" },
    { "path": "./tests" }
  ]
}
